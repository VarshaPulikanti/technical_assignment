# Copy to backend/.env (and optionally frontend/.env.local)

# --- OpenAI (default; needs billing/credits on platform.openai.com) ---
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# --- FREE local option: install Ollama, then run:
#   ollama pull llama3.2
#   ollama pull nomic-embed-text
# LLM_PROVIDER=ollama
# EMBEDDING_PROVIDER=ollama
# OLLAMA_MODEL=llama3.2
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_BASE_URL=http://localhost:11434

# --- FREE cloud option: https://aistudio.google.com/apikey ---
# LLM_PROVIDER=gemini
# EMBEDDING_PROVIDER=ollama
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Chroma persistence (relative to backend/ when running uvicorn)
CHROMA_PERSIST_DIR=./data/chroma
CHUNK_SIZE=500
CHUNK_OVERLAP=80
MAX_CHUNKS_PER_VIDEO=20

# Frontend talks to API
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# Optional — export Instagram cookies (Netscape format) to get view counts on Reels
# See: https://github.com/yt-dlp/yt-dlp/wiki/FAQ#how-do-i-pass-cookies-to-yt-dlp
YTDLP_COOKIES_FILE=
