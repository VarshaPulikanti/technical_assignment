# Copy to backend/.env and add your keys. Never commit backend/.env.

LLM_PROVIDER=gemini
EMBEDDING_PROVIDER=local
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Ollama (optional — for chat only; indexing uses local embeddings above)
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# OpenAI (optional)
# LLM_PROVIDER=openai
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small

CHROMA_PERSIST_DIR=./data/chroma
CHUNK_SIZE=500
CHUNK_OVERLAP=80
MAX_CHUNKS_PER_VIDEO=20

NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# Netscape cookies.txt path for Instagram view counts (optional)
YTDLP_COOKIES_FILE=
